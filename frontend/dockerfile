FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies (handle ARM64 rollup binary issue)
RUN rm -f package-lock.json && \
    npm install --force && \
    npm install --save-optional @rollup/rollup-linux-arm64-gnu

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Start dev server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
