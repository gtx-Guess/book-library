# Google Books API Key — get one at console.cloud.google.com
GOOGLE_BOOKS_API_KEY=your_api_key_here

# Auth — generate a secret with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret
OWNER_PASSWORD=changeme

# WebAuthn — set to your public domain (HTTPS required)
WEBAUTHN_RP_ID=book.yourdomain.com
WEBAUTHN_ORIGIN=https://book.yourdomain.com

# For public/production deployment — leave empty for local dev
VITE_API_URL=

# Database
POSTGRES_USER=booktracker
POSTGRES_PASSWORD=booktracker_password
POSTGRES_DB=booktracker
